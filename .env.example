# Copy to .env to override defaults. All keys are optional.

# Bind address and port. Keep the host on loopback unless you set an API key.
# 8189 avoids clashing with FlareSolverr's 8191.
# SLIPGATE_HOST=127.0.0.1
# SLIPGATE_PORT=8189

# Require X-Slipgate-Key on every /resolve when set.
# SLIPGATE_API_KEY=

# The FlareSolverr /v1 endpoint that does the gate clearing.
# SLIPGATE_FLARESOLVERR_URL=http://localhost:8191/v1
# SLIPGATE_FLARESOLVERR_TIMEOUT_MS=60000
# SLIPGATE_FLARESOLVERR_HTTP_TIMEOUT_SECS=90

# Overall per-resolve ceiling and concurrency.
# SLIPGATE_RESOLVE_TIMEOUT_SECS=150
# SLIPGATE_MAX_CONCURRENCY=2

# SLIPGATE_LOG_LEVEL=info
